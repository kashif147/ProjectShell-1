{
  "version": 2,
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096",
      "GENERATE_SOURCEMAP": "false"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

